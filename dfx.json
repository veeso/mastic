{
  "dfx": "0.27.0",
  "canisters": {
    "directory": {
      "type": "rust",
      "package": "directory",
      "candid": "./.artifact/directory.did",
      "declarations": {
        "node_compatibility": true
      }
    },
    "federation": {
      "type": "rust",
      "package": "federation",
      "candid": "./.artifact/federation.did",
      "declarations": {
        "node_compatibility": true
      }
    },
    "user": {
      "type": "rust",
      "package": "user",
      "candid": "./.artifact/user.did",
      "declarations": {
        "node_compatibility": true
      }
    },
    "orbit-station": {},
    "orbit-upgrader": {}
  },
  "defaults": {
    "build": {
      "packtool": ""
    }
  },
  "networks": {
    "local": {
      "bind": "127.0.0.1:8080",
      "type": "ephemeral",
      "replica": {
        "subnet_type": "system",
        "port": 4943
      }
    }
  },
