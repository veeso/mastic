{
  "dfx": "0.27.0",
  "canisters": {
    "mastic": {
      "type": "rust",
      "package": "mastic",
      "candid": "./.artifact/mastic.did",
      "declarations": {
        "node_compatibility": true
      }
    }
  },
  "defaults": {
    "build": {
      "packtool": ""
    }
